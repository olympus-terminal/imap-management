#!/usr/bin/env bash
#
# Gmail cleanup wrapper - zum8zum@gmail.com
# Usage: ./gmail <command> [query] [options]
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CLEANUP="$SCRIPT_DIR/gmail_cleanup.py"
EMAIL="zum8zum@gmail.com"
PASSWORD_FILE="$SCRIPT_DIR/app_password.txt"

# Defaults
BATCH_SIZE=500
DELAY=1.0

usage() {
    cat <<'EOF'
Gmail Cleanup Tool - zum8zum@gmail.com

Usage: gmail <command> [gmail-query] [options]

Commands:
  preview <query>     Preview matching emails (dry run)
  delete  <query>     Delete matching emails (with confirmation)
  analyze             Analyze inbox for cleanup opportunities
  folders             List all folders/labels
  empty-trash         Permanently empty trash
  empty-spam          Empty spam folder

Options:
  -f, --folder NAME   Target folder (inbox, sent, all, spam, trash, promotions, social)
  -b, --batch N       Batch size (default: 500)
  -d, --delay N       Seconds between batches (default: 1.0)
  -l, --limit N       Limit results (default: 100)
  --no-loop           Don't loop (single pass only)

Gmail query examples (same syntax as Gmail web UI):
  "from:github.com"
  "from:notifications@github.com older_than:1y"
  "category:promotions older_than:6m"
  "has:attachment larger:5M"
  "older_than:2y"

Examples:
  gmail preview "from:github.com"
  gmail delete "from:github.com"
  gmail delete "category:promotions older_than:6m" --batch 1000
  gmail analyze
  gmail analyze --folder all --limit 500
  gmail empty-trash
EOF
    exit 0
}

# Check password file exists
check_auth() {
    if [[ ! -f "$PASSWORD_FILE" ]]; then
        echo "Error: App password file not found at $PASSWORD_FILE"
        echo ""
        echo "Setup:"
        echo "  1. Go to https://myaccount.google.com/apppasswords"
        echo "  2. Create an app password for 'imap-cleanup'"
        echo "  3. Save it:"
        echo "     echo 'xxxx xxxx xxxx xxxx' > $PASSWORD_FILE"
        echo "     chmod 600 $PASSWORD_FILE"
        exit 1
    fi
}

[[ $# -eq 0 ]] && usage

COMMAND="$1"
shift

# Parse remaining args
QUERY=""
FOLDER="inbox"
LIMIT=100
LOOP="--loop"
EXTRA_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -f|--folder)  FOLDER="$2"; shift 2 ;;
        -b|--batch)   BATCH_SIZE="$2"; shift 2 ;;
        -d|--delay)   DELAY="$2"; shift 2 ;;
        -l|--limit)   LIMIT="$2"; shift 2 ;;
        --no-loop)    LOOP=""; shift ;;
        -h|--help)    usage ;;
        *)
            if [[ -z "$QUERY" ]]; then
                QUERY="$1"
            else
                EXTRA_ARGS+=("$1")
            fi
            shift
            ;;
    esac
done

AUTH_ARGS=(-e "$EMAIL" --password-file "$PASSWORD_FILE")

case "$COMMAND" in
    preview)
        [[ -z "$QUERY" ]] && { echo "Error: preview requires a Gmail query"; echo "  e.g., gmail preview \"from:github.com\""; exit 1; }
        check_auth
        python3 "$CLEANUP" "${AUTH_ARGS[@]}" -f "$FOLDER" -g "$QUERY" --preview --limit "$LIMIT"
        ;;
    delete)
        [[ -z "$QUERY" ]] && { echo "Error: delete requires a Gmail query"; echo "  e.g., gmail delete \"from:github.com\""; exit 1; }
        check_auth
        python3 "$CLEANUP" "${AUTH_ARGS[@]}" -f "$FOLDER" -g "$QUERY" \
            --batch-size "$BATCH_SIZE" --delay "$DELAY" $LOOP --delete --yes --limit "$LIMIT"
        ;;
    analyze)
        check_auth
        python3 "$CLEANUP" "${AUTH_ARGS[@]}" -f "$FOLDER" --analyze --limit "$LIMIT"
        ;;
    folders)
        check_auth
        python3 "$CLEANUP" "${AUTH_ARGS[@]}" --list-folders
        ;;
    empty-trash)
        check_auth
        python3 "$CLEANUP" "${AUTH_ARGS[@]}" --empty-trash
        ;;
    empty-spam)
        check_auth
        python3 "$CLEANUP" "${AUTH_ARGS[@]}" --empty-spam
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        echo "Unknown command: $COMMAND"
        echo "Run 'gmail help' for usage"
        exit 1
        ;;
esac
